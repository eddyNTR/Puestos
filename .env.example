# Este archivo es un EJEMPLO de configuración
# NO SUBIR VALORES REALES A GIT
# Copiar este archivo como .env y agregar sus valores reales

# Google Maps API Key - CRÍTICO: No subir a GitHub
GOOGLE_MAPS_API_KEY=TU_API_KEY_AQUI

# Firebase Configuration - Obtener de Firebase Console
FIREBASE_API_KEY=TU_FIREBASE_API_KEY_AQUI
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_MESSAGING_SENDER_ID=TU_MESSAGING_SENDER_ID
FIREBASE_APP_ID=TU_APP_ID_AQUI

# Base de datos
DATABASE_PATH=puestos.db

# Configuración de la aplicación
APP_NAME=Gestión de Puestos EMSA
APP_VERSION=1.0.0
